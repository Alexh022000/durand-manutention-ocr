# Clé API Mistral - requise pour la lecture des plans
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-api-key-here

# Modèle OCR utilisé pour lire le plan PDF / image (défaut : mistral-ocr-latest)
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Modèle de raisonnement pour structurer le JSON + confiance par champ
# (défaut : mistral-large-latest)
MISTRAL_MODEL=mistral-large-latest
